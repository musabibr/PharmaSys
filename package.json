{
  "name": "pharmasys",
  "version": "1.0.0",
  "description": "Premium Pharmacy Management System",
  "main": "dist-ts/platform/electron/main.js",
  "scripts": {
    "start": "vite build && npm run compile && node scripts/electron-run.js .",
    "dev": "concurrently \"vite\" \"npm run compile && node scripts/electron-run.js . --dev\"",
    "compile": "tsc && node scripts/post-compile.js",
    "compile:watch": "tsc --watch",
    "build": "vite build && npm run compile && electron-builder --win",
    "build:nsis": "vite build && npm run compile && electron-builder --win nsis",
    "build:portable": "vite build && npm run compile && electron-builder --win portable",
    "build:dir": "vite build && npm run compile && electron-builder --win dir",
    "build:signed": "vite build && npm run compile && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "tsc": "tsc --noEmit",
    "tsc:build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start:server": "tsx src/platform/server/index.ts",
    "start:server:pg": "cross-env DB_TYPE=postgres tsx src/platform/server/index.ts",
    "license-bot": "node tools/license-bot.js"
  },
  "keywords": [
    "pharmacy",
    "pos",
    "inventory",
    "management"
  ],
  "author": "PharmaSys",
  "license": "MIT",
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "i18next": "^25.8.13",
    "jest": "^30.2.0",
    "lucide-react": "^0.575.0",
    "node-telegram-bot-api": "^0.67.0",
    "postcss": "^8.5.6",
    "promptfoo": "^0.121.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "supertest": "^7.2.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "zustand": "^5.0.11"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "pdfjs-dist": "^5.5.207",
    "shepherd.js": "^15.2.1",
    "sql.js": "^1.10.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "pg": "^8.13.0"
  },
  "build": {
    "appId": "com.pharmasys.app",
    "productName": "PharmaSys",
    "copyright": "Copyright 2024 PharmaSys",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist-ts/**/*",
      "dist-renderer/**/*",
      "src/main/preload.js",
      "src/main/preload-rest.js",
      "node_modules/**/*",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/*.md",
      "!node_modules/**/*.map",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/README*",
      "!node_modules/**/.github/**",
      "!node_modules/**/.eslintrc*",
      "!node_modules/**/.prettierrc*",
      "!node_modules/**/tsconfig.json",
      "!node_modules/**/jest.config*",
      "!node_modules/**/karma.conf*",
      "!node_modules/**/Makefile",
      "!node_modules/**/Gruntfile*",
      "!node_modules/**/Gulpfile*",
      "!node_modules/**/bower.json",
      "!node_modules/**/.travis.yml"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "build/pdf_invoice_parser.exe",
        "to": "pdf_invoice_parser.exe",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "icon": "build/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PharmaSys",
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "installerLanguages": [
        "en_US"
      ],
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "compression": "maximum",
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/dist/**"
    ],
    "removePackageScripts": true
  }
}

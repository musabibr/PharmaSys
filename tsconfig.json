{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist-ts",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": "./src",
    "paths": {
      "@core/*": ["core/*"],
      "@transport/*": ["transport/*"],
      "@platform/*": ["platform/*"]
    }
  },
  "include": [
    "src/core/**/*.ts",
    "src/transport/**/*.ts",
    "src/platform/**/*.ts",
    "src/license/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-ts",
    "tests",
    "src/main/**/*.js",
    "src/renderer/**/*",
    "src/common/**/*.js"
  ]
}

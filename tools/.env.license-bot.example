# PharmaSys License Bot — Environment Variables
#
# 1. Get a bot token from @BotFather on Telegram
# 2. Get your user ID from @userinfobot on Telegram
# 3. Copy this file to .env.license-bot and fill in the values
# 4. Run: npm run license-bot

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id_here
